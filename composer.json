{
  "name": "token27/nexus-ai-prompts",
  "description": "Framework-agnostic prompt registry with Mustache templating, versioning, multi-language fallback, and multi-directory support",
  "type": "library",
  "homepage": "https://github.com/token27/nexus-ai-prompts",
  "authors": [
    {
      "name": "Token27",
      "homepage": "https://github.com/token27",
      "role": "Maintainer"
    },
    {
      "name": "Contributors",
      "homepage": "https://github.com/token27/nexus-ai-prompts/graphs/contributors",
      "role": "Contributor"
    }
  ],
  "keywords": [
    "prompts",
    "mustache",
    "templating",
    "versioning",
    "i18n",
    "registry",
    "php"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "league/flysystem": "^3.0",
    "mustache/mustache": "^2.14"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Token27\\NexusAI\\Prompts\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Token27\\NexusAI\\Prompts\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite Unit",
    "test:integration": "phpunit --testsuite Integration",
    "test:coverage": "phpunit --coverage-text",
    "lint": "php-cs-fixer fix --dry-run --diff",
    "lint-fix": "php-cs-fixer fix",
    "analyse": "phpstan analyse --level=8 src/",
    "check": [
      "@lint",
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
